# Tablo account credentials
TABLO_EMAIL=
TABLO_PASSWORD=

# Server config
PORT=9480

# How many days of guide data to fetch (1-7)
GUIDE_DAYS=2

# Encoder: "gpu" (macOS Swift/VideoToolbox) or "cpu" (FFmpeg)
# On macOS CPU mode: h264_videotoolbox. On Linux: auto-detects VAAPI → QSV → libx264
# ENCODER=gpu

# Override FFmpeg path (Linux default: "ffmpeg" from PATH, macOS: /opt/homebrew/bin/ffmpeg)
# FFMPEG_PATH=/usr/bin/ffmpeg
